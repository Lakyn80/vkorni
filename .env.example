DEEPSEEK_KEY=sk-your-key
DEEPSEEK_API=https://api.deepseek.com/v1/chat

VKORNI_BASE_URL=https://vkorni.com/api
VKORNI_API_KEY=replace-me
VKORNI_NODE_ID=8
VKORNI_USER_ID=1

BACKEND_PUBLIC_URL=http://localhost:8020
# Optional direct browser-to-backend base URL. Leave empty in production when
# the frontend proxies /api and /static to the backend internally.
NEXT_PUBLIC_API_BASE=
# Internal frontend -> backend proxy target used by Next.js rewrites.
API_PROXY_TARGET=http://backend:8000

REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-before-deploy
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

WIKI_LANG=ru
WIKI_USER_AGENT=vkorni-bot/1.0 (contact: admin@vkorni.ru)
WIKI_MAX_IMAGES=5
WIKIDATA_BASE_URL=https://www.wikidata.org
WIKI_REQUEST_TIMEOUT_SECONDS=10
WIKI_IMAGE_TIMEOUT_SECONDS=15
WIKI_REQUEST_DELAY_SECONDS=0.5
WIKI_REQUEST_JITTER_SECONDS=1.0
WIKI_REQUEST_MAX_RETRIES=5
WIKI_REQUEST_BACKOFF_SECONDS=1.0
WIKI_RATE_LIMIT_BACKOFF_SECONDS=5.0
WIKI_RATE_LIMIT_PER_SEC=1

IMAGE_BATCH_SIZE=2
IMAGE_ACCEPTED_DIR=/app/static/accepted_images
IMAGE_REJECTED_DIR=/app/static/rejected_images
PHOTOS_DIR=/app/static/photos
FRAMES_DIR=/app/frames
CHROMA_PATH=/app/chroma_data

WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY=5
BULK_EXPORT_ITEM_TIMEOUT=900
BULK_EXPORT_MAX_ATTEMPTS=5
BULK_EXPORT_RETRY_DELAY_SECONDS=15
BULK_EXPORT_WATCHDOG_INTERVAL_SECONDS=60
BULK_EXPORT_STALL_SECONDS=180

# Optional: Google Vision API key string. Leave empty to skip validation.
GOOGLE_VISION_API_KEY=
